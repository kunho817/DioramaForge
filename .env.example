# Copy this file to .env.local for local demo runs.
# Do not commit .env.local; it may contain API keys.
# Process environment variables override values from this file.

# Optional: launch ComfyUI automatically from scripts/start_diorama_forge.bat.
# COMFYUI_DIR=D:\ComfyUI

# Required when configs/default.json uses stage4_backend_mode=meshy or stage5_backend_mode=meshy.
# MESHY_API_KEY=msy_your_key_here

# Optional legacy remote path. Keep disabled for the current local-first demo.
# DIORAMA_ENABLE_REMOTE_TUNNEL=0
